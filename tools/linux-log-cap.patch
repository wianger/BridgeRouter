index 000000000000..99aafbcb8e8f
--- /dev/null
+++ b/kernel/log_cap.c
@@ -0,0 +1,209 @@
+// SPDX-License-Identifier: GPL-2.0
+/*
+ * Minimal runtime support for BridgeRouter's LLVM capability logging pass.
+ */
+
+#include <linux/errno.h>
+#include <linux/kernel.h>
+#include <linux/sched.h>
+#include <linux/spinlock.h>
+#include <linux/syscalls.h>
+#include <linux/types.h>
+#include <linux/uaccess.h>
+
+#define LOG_CAP_MAX_INFOS	128
+#define LOG_CAP_MAX_SESSIONS	64
+
+#define LOG_CAP_KIND_ALLOC	0
+#define LOG_CAP_KIND_COPY	1
+#define LOG_CAP_KIND_FUNC	2
+
+struct log_cap_info {
+	u8 kind;
+	u8 stIndex;
+	u16 siteID;
+};
+
+struct log_cap_session {
+	pid_t pid;
+	bool active;
+	unsigned int size;
+	struct log_cap_info infos[LOG_CAP_MAX_INFOS];
+};
+
+static DEFINE_SPINLOCK(log_cap_lock);
+static struct log_cap_session log_cap_sessions[LOG_CAP_MAX_SESSIONS];
+
+static struct log_cap_session *log_cap_find_locked(pid_t pid)
+{
+	int i;
+
+	for (i = 0; i < LOG_CAP_MAX_SESSIONS; i++) {
+		if (log_cap_sessions[i].pid == pid)
+			return &log_cap_sessions[i];
+	}
+
+	return NULL;
+}
+
+static struct log_cap_session *log_cap_alloc_locked(pid_t pid)
+{
+	struct log_cap_session *session;
+	int i;
+
+	session = log_cap_find_locked(pid);
+	if (session)
+		return session;
+
+	for (i = 0; i < LOG_CAP_MAX_SESSIONS; i++) {
+		if (!log_cap_sessions[i].pid) {
+			session = &log_cap_sessions[i];
+			session->pid = pid;
+			session->active = false;
+			session->size = 0;
+			return session;
+		}
+	}
+
+	for (i = 0; i < LOG_CAP_MAX_SESSIONS; i++) {
+		if (!log_cap_sessions[i].active) {
+			session = &log_cap_sessions[i];
+			session->pid = pid;
+			session->active = false;
+			session->size = 0;
+			return session;
+		}
+	}
+
+	return NULL;
+}
+
+static void log_cap_reset_locked(struct log_cap_session *session)
+{
+	if (!session)
+		return;
+
+	session->active = false;
+	session->size = 0;
+}
+
+static void log_cap_add_locked(struct log_cap_session *session, u8 kind,
+			       u8 st_index, u16 site_id)
+{
+	unsigned int i;
+
+	if (!session || !session->active)
+		return;
+
+	for (i = 0; i < session->size; i++) {
+		if (session->infos[i].kind == kind &&
+		    session->infos[i].stIndex == st_index &&
+		    session->infos[i].siteID == site_id)
+			return;
+	}
+
+	if (session->size >= LOG_CAP_MAX_INFOS)
+		return;
+
+	session->infos[session->size].kind = kind;
+	session->infos[session->size].stIndex = st_index;
+	session->infos[session->size].siteID = site_id;
+	session->size++;
+}
+
+void notrace log_cap(const void *dst, const void *src, s64 len, u8 st_index,
+		     u16 site_id, u8 kind)
+{
+	struct log_cap_session *session;
+	unsigned long flags;
+	pid_t pid;
+
+	(void)dst;
+	(void)src;
+	(void)len;
+
+	pid = task_pid_nr(current);
+	if (!pid)
+		return;
+	if (kind > LOG_CAP_KIND_FUNC)
+		return;
+
+	spin_lock_irqsave(&log_cap_lock, flags);
+	session = log_cap_find_locked(pid);
+	log_cap_add_locked(session, kind, st_index, site_id);
+	spin_unlock_irqrestore(&log_cap_lock, flags);
+}
+
+SYSCALL_DEFINE0(myinit)
+{
+	struct log_cap_session *session;
+	unsigned long flags;
+	pid_t pid = task_pid_nr(current);
+
+	if (!pid)
+		return -ESRCH;
+
+	spin_lock_irqsave(&log_cap_lock, flags);
+	session = log_cap_alloc_locked(pid);
+	if (!session) {
+		spin_unlock_irqrestore(&log_cap_lock, flags);
+		return -ENOMEM;
+	}
+	session->size = 0;
+	session->active = true;
+	spin_unlock_irqrestore(&log_cap_lock, flags);
+
+	return 0;
+}
+
+SYSCALL_DEFINE0(myfinal)
+{
+	struct log_cap_session *session;
+	unsigned long flags;
+	pid_t pid = task_pid_nr(current);
+
+	if (!pid)
+		return -ESRCH;
+
+	spin_lock_irqsave(&log_cap_lock, flags);
+	session = log_cap_find_locked(pid);
+	if (session)
+		session->active = false;
+	spin_unlock_irqrestore(&log_cap_lock, flags);
+
+	return 0;
+}
+
+SYSCALL_DEFINE1(get_log_cap, struct log_cap_info __user *, ubuf)
+{
+	struct log_cap_info snapshot[LOG_CAP_MAX_INFOS];
+	struct log_cap_session *session;
+	unsigned long flags;
+	unsigned int size = 0;
+	pid_t pid = task_pid_nr(current);
+
+	if (!pid)
+		return -ESRCH;
+
+	spin_lock_irqsave(&log_cap_lock, flags);
+	session = log_cap_alloc_locked(pid);
+	if (!session) {
+		spin_unlock_irqrestore(&log_cap_lock, flags);
+		return -ENOMEM;
+	}
+
+	if (!ubuf) {
+		log_cap_reset_locked(session);
+		spin_unlock_irqrestore(&log_cap_lock, flags);
+		return 0;
+	}
+
+	size = session->size;
+	memcpy(snapshot, session->infos, size * sizeof(snapshot[0]));
+	spin_unlock_irqrestore(&log_cap_lock, flags);
+
+	if (copy_to_user(ubuf, snapshot, size * sizeof(snapshot[0])))
+		return -EFAULT;
+
+	return size;
+}
